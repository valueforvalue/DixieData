# Build artifacts
build/bin/
build/log/
build/release/
build/darwin/
build/windows/
build/linux/
internal/archive/build/
DixieData
DixieData.exe
*.exe
*.test

# Frontend build outputs
frontend/dist/
frontend/app.css
frontend/wailsjs/
frontend/node_modules/
node_modules/

# Templ generated files
internal/templates/*_templ.go
internal/templates/*_templ.txt
*_templ.go
*_templ.txt

# Database files (user data)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
*-wal
*-shm
*-journal

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
.cursor/
.aider*

# User data directory
.dixiedata/
dixiedata-backup-*.ddbak

# Go test cache
*.out
coverage.out
*.prof

# Project secrets + telemetry
google-oauth-defaults.json
google-oauth-defaults.example.json
feedback.jsonl

# Releases + test artifacts
release/
tests/goldmaster/artifacts/
tests/stress/artifacts/
tests/goldmaster/playwright/node_modules/
tests/goldmaster/playwright/test-results/
tests/goldmaster/playwright/playwright-report/

# Copilot transient
.copilot-temp/

# rpiv-workflow runtime state
.rpiv/runs/
.rpiv/artifacts/

# my-skills-framework — symlinks are project-local, regenerated by bootstrap
.pi/skills/

# PDF render artifacts. docs/renderings/<surface>/{pre-iteration,round-*}
# are regenerated by `make render-round` and are not source — the
# source is templates/*.typ. review.md, README.md, and
# TERMINOLOGY.md remain tracked.
docs/renderings/**/pre-iteration.pdf
docs/renderings/**/round-*.pdf
# Native-SVG and PNG preview artifacts written by `make render-svg`
# (or render-svg.sh). Multi-page surfaces emit one file per page
# (round-{N,p}.svg), so these can balloon quickly during iteration.
docs/renderings/**/round-*.svg
docs/renderings/**/round-*.png

# UI/UX audit harness (issue #74). The harness reports/screenshots are
# regenerated by `node audit/run.mjs` and friends; only the harness
# sources and JSON reports are tracked.
audit/screenshots/
audit/screenshots-r2/
audit/screenshots-r3/

# dixiedata-web scratch data dir. Web-mode runs write a sqlite db + images
# here so they don't touch .dixiedata/. Regenerated by `make web-run` +
# `make web-seed`.
.scratch/
